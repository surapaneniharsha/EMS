<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" >
    <Properties>
        <Property name="log-path">logs</Property>
        <Property name="file-name">ems.log</Property>
        <Property name="log-pattern">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %M %C - %msg%n</Property>
    </Properties>

    <Appenders>

        <File name="FileLogger" fileName="${log-path}/${file-name}">
            <PatternLayout pattern="${log-pattern}" />
        </File>

        <RollingFile name="RollingFile" fileName="${log-path}/emsroll.log"
                     filePattern="${log-path}/emsrolling-%i.log.gz">
            <PatternLayout pattern="${log-pattern}" />
            <Policies>
                <SizeBasedTriggeringPolicy size="10MB" />
            </Policies>
            <DefaultRolloverStrategy max="10" />
        </RollingFile>

    </Appenders>

    <Loggers>

        <Logger  name="com.infinira.ems" level="info" additivity="false">
            <AppenderRef ref="RollingFile" />
        </Logger>

        <Root level="info">
            <AppenderRef ref="FileLogger" />
        </Root>

    </Loggers>

</Configuration>
